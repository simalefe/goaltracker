# =============================================
# GoalTracker Pro — Ortam Değişkenleri
# Kopyala: cp .env.example .env
# =============================================

# ---- Sunucu ----
SERVER_PORT=8080

# ---- Veritabanı ----
# Geliştirme: jdbc:h2:mem:goaltracker;DB_CLOSE_DELAY=-1
# Üretim:    jdbc:h2:file:./data/goaltracker;DB_CLOSE_ON_EXIT=FALSE
DATABASE_URL=jdbc:h2:mem:goaltracker;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DATABASE_USERNAME=sa
DATABASE_PASSWORD=

# ---- JWT (Zorunlu — en az 32 karakter rastgele secret) ----
# Örnek üretme: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-256-bit-secret-key-at-least-32-chars
JWT_ACCESS_EXP=900000
JWT_REFRESH_EXP=604800000

# ---- E-posta (SMTP) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@goaltracker.app
MAIL_PASSWORD=your-app-specific-password

# ---- Uygulama ----
APP_BASE_URL=http://localhost:8080

# ---- Spring Profili ----
# Geliştirme: dev  |  Üretim: prod
SPRING_PROFILES_ACTIVE=dev

