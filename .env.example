# =============================================
# GoalTracker Pro — Environment Variables
# Kopyala: cp .env.example .env
# =============================================

# JWT (Phase 1 — şimdilik placeholder)
JWT_SECRET=change-me-to-a-random-256-bit-secret-key-at-least-32-chars
JWT_ACCESS_EXP=900000
JWT_REFRESH_EXP=604800000

# SMTP Mail (Phase 1 — şimdilik placeholder)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@goaltracker.app
MAIL_PASSWORD=your-app-specific-password

